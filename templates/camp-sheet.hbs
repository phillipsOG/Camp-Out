<div class="camp-out-shell">

  {{#unless hasCharacter}}
    <div class="camp-out-empty">
      <i class="fa-solid fa-user-slash"></i>
      <p>{{localize "CAMPOUT.sheet.noCharacter"}}</p>
    </div>
  {{else}}

    <header class="camp-out-banner is-active">
      <div class="camp-out-banner-text">
        <h2><i class="fa-solid fa-fire"></i> {{participant.name}}</h2>
        <p>
          {{#if slumbering}}
            {{localize "CAMPOUT.sheet.slumbering"}}
          {{else if rested}}
            {{localize "CAMPOUT.sheet.rested" }}
          {{else}}
            {{localize "CAMPOUT.sheet.underslept"}}
          {{/if}}
          <span class="camp-out-count">{{sleepHours}}/{{requiredHours}}h</span>
          {{#if trance}}<span class="camp-out-badge is-trance">{{localize "CAMPOUT.common.trance"}}</span>{{/if}}
          {{#if assistWatches}}<span class="camp-out-badge is-assist">{{localize "CAMPOUT.sheet.assisting"}}</span>{{/if}}
        </p>
      </div>

      <div class="camp-out-banner-tools">
        <button type="button" class="camp-out-icon-btn" data-action="theme"
                data-tooltip="{{themeLabel}}" aria-label="{{themeLabel}}">
          <i class="{{themeIcon}}"></i>
        </button>
        <button type="button" data-action="clear" {{#if locked}}disabled{{/if}}>
          <i class="fa-solid fa-eraser"></i> {{localize "CAMPOUT.sheet.clear"}}
        </button>
        <button type="button" class="camp-out-primary" data-action="ready" {{#if locked}}disabled{{/if}}>
          {{#if participant.ready}}
            <i class="fa-solid fa-circle-check"></i> {{localize "CAMPOUT.sheet.unready"}}
          {{else}}
            <i class="fa-regular fa-circle"></i> {{localize "CAMPOUT.sheet.markReady"}}
          {{/if}}
        </button>
      </div>
    </header>

    {{#if multipleCharacters}}
      <nav class="camp-out-actor-picker">
        {{#each characters}}
          <button type="button" class="camp-out-actor {{#if active}}is-active{{/if}}"
                  data-action="selectActor" data-actor-id="{{actorId}}">
            <img src="{{img}}" alt="{{name}}" /> <span>{{name}}</span>
          </button>
        {{/each}}
      </nav>
    {{/if}}

    <section class="camp-out-body camp-out-scroll">
      {{#if locked}}
        <p class="camp-out-hint">
          <i class="fa-solid fa-lock"></i> {{localize "CAMPOUT.sheet.lockedHint"}}
        </p>
      {{/if}}

      <div class="camp-out-hbar">
        <div class="camp-out-hbar-label">{{progressLabel}}</div>
        <div class="camp-out-hbar-rail">
          <div class="camp-out-hbar-rail-fill" style="width: {{progressPercent}}%"></div>
        </div>
        <div class="camp-out-hbar-track">
          <div class="camp-out-hbar-segments">
            {{#each rows}}
              <button type="button"
                      class="camp-out-hbar-segment
                        {{#if selected}}is-selected{{/if}}
                        {{#if current}}is-current{{/if}}
                        {{#if resolved}}is-resolved{{/if}}
                        {{#if assisting}}is-assisting{{/if}}
                        {{#if asleep}}is-asleep{{/if}}"
                      style="--cell-color: {{color}}"
                      data-action="selectWatch" data-watch="{{watch}}"
                      data-tooltip="{{assignedLabel}}">
                <span class="camp-out-hbar-marker"><i class="{{assignedIcon}}"></i></span>
                <span class="camp-out-hbar-hours">{{hours}}</span>
                <span class="camp-out-hbar-choice">{{assignedLabel}}</span>
              </button>
            {{/each}}
          </div>
        </div>
      </div>

      {{#if selectedRow}}
        <section class="camp-out-watch-panel {{#if selectedRow.resolved}}is-resolved{{/if}} {{#if selectedRow.current}}is-current{{/if}}">
          <header class="camp-out-watch-header">
            <h3>{{selectedRow.label}} <small>{{selectedRow.hours}}</small></h3>
            <span class="camp-out-current-choice {{#if selectedRow.assisting}}is-assist{{/if}}">
              <i class="{{selectedRow.assignedIcon}}"></i> {{selectedRow.assignedLabel}}
            </span>
          </header>

          <div class="camp-out-action-cards">
            {{#each choices}}
              <button type="button"
                      class="camp-out-action-card {{#if selected}}is-selected{{/if}}"
                      style="--cell-color: {{color}}"
                      data-action="assign" data-watch="{{watch}}" data-action-id="{{id}}"
                      data-tooltip="{{details}}"
                      {{#if disabled}}disabled{{/if}}>
                <i class="{{icon}}"></i>
                <span class="camp-out-action-label">{{label}}</span>
              </button>
            {{/each}}
          </div>
        </section>
      {{/if}}

      <section class="camp-out-note">
        <label>{{localize "CAMPOUT.sheet.note"}}</label>
        <textarea data-note rows="2"
                  placeholder="{{localize 'CAMPOUT.sheet.notePlaceholder'}}">{{note}}</textarea>
      </section>

      {{#if roster.length}}
        <section class="camp-out-party">
          <h3><i class="fa-solid fa-users"></i> {{localize "CAMPOUT.sheet.party"}}</h3>
          <ul class="camp-out-party-list">
            {{#each roster}}
              <li>
                <img src="{{img}}" alt="{{name}}" />
                <div class="camp-out-party-text">
                  <strong>{{name}}</strong>
                  <div class="camp-out-hbar-mini">
                    {{#each watches}}
                      <span class="camp-out-hbar-mini-seg
                          {{#if current}}is-current{{/if}}
                          {{#if resolved}}is-resolved{{/if}}
                          {{#unless visible}}is-hidden{{/unless}}"
                            style="--cell-color: {{color}}"
                            data-tooltip="{{label}}">
                        <i class="{{icon}}"></i>
                      </span>
                    {{/each}}
                  </div>
                </div>
                {{#if trance}}<span class="camp-out-badge is-trance">{{localize "CAMPOUT.common.trance"}}</span>{{/if}}
                {{#if ready}}<span class="camp-out-badge is-ready">{{localize "CAMPOUT.planner.ready"}}</span>{{/if}}
              </li>
            {{/each}}
          </ul>
        </section>
      {{/if}}
    </section>

  {{/unless}}
</div>
